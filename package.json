{
  "name": "lottopilot",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8082",
    "scrape": "ts-node --project scripts/tsconfig.json scripts/scrape-draws.ts",
    "scrape:history": "cross-env FETCH_HISTORY=1 ts-node --project scripts/tsconfig.json scripts/scrape-draws.ts",
    "add-missing": "ts-node --project scripts/tsconfig.json scripts/add-missing-draw.ts",
    "seed": "ts-node --project scripts/tsconfig.json scripts/seed-draws.ts",
    "seed:encore": "ts-node --project scripts/tsconfig.json scripts/seed-encore-draw.ts",
    "compass:update": "ts-node --project scripts/tsconfig.json scripts/update-compass.ts",
    "test": "node node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "@supabase/supabase-js": "^2.97.0",
    "expo": "^54.0.33",
    "expo-dev-client": "~6.0.20",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "^17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "^8.0.11",
    "expo-location": "~19.0.8",
    "expo-mlkit-ocr": "^2.0.1",
    "expo-notifications": "^0.32.16",
    "expo-secure-store": "^15.0.8",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "fetch-retry": "^6.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-document-scanner-plugin": "^2.0.4",
    "react-native-google-mobile-ads": "^16.3.0",
    "react-native-iap": "^14.7.12",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "unpdf": "^1.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  },
  "private": true
}
